# Copy to .env in the repository root, then set values. Example:
#   cp env.example .env
# Many commands and scripts in this repo expect these variables in the environment:
#   set -a && source .env && set +a
#   # or, from the repo root:
#   . scripts/load-env.sh
#
export AWS_REGION=us-east-1
export AWS_ACCOUNT_ID=123456789012
#
# Optional: override the default ECR image URI
# (default: ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/eks-mcp-bridge:latest)
# export EKS_MCP_BRIDGE_IMAGE=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/eks-mcp-bridge:latest
#
# EKS cluster name (use in Step 3 eksctl and Step 5 describe-cluster commands)
# export EKS_CLUSTER_NAME=my-cluster
#
# Set before rendering manifests (Step 5). Generate a value with: openssl rand -base64 32
# export API_ACCESS_TOKEN=
