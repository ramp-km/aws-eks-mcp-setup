{
  "mcpServers": {
    "aws-eks-mcp": {
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws@latest",
        "https://eks-mcp.<aws-region>.api.aws/mcp",
        "--service",
        "eks-mcp",
        "--region",
        "<aws-region>"
      ],
      "env": {
        "AWS_REGION": "<aws-region>"
      }
    }
  }
}
