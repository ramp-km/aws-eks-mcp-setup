{
  "mcpServers": {
    "aws-eks-mcp": {
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws@latest",
        "https://eks-mcp.${AWS_REGION}.api.aws/mcp",
        "--service",
        "eks-mcp",
        "--region",
        "${AWS_REGION}"
      ],
      "env": {
        "AWS_REGION": "${AWS_REGION}"
      }
    }
  }
}
